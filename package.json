{
    "name": "supercritical",
    "private": true,
    "packageManager": "pnpm@11.5.1",
    "scripts": {
        "build": "turbo run build",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "db:generate": "pnpm --filter @supercritical/db generate",
        "postinstall": "pnpm --filter @supercritical/db exec prisma generate --no-engine"
    },
    "devDependencies": {
        "turbo": "2.9.17"
    }
}
